rules_version = '2';

// ============================================================
// قواعد أمان Firestore — قفل خفيف لمنع مسح البيانات بالخطأ
// ------------------------------------------------------------
// الاستخدام داخلي (بلا Firebase Auth حاليًا)، لذا القراءة/الكتابة مفتوحة،
// لكن نحمي أثمن وثيقة (settings/config التي تحوي كل الحسابات والمجموعات)
// من الحذف نهائيًا، ونحصر الكتابة في الكولكشنات المعروفة فقط.
//
// كيفية التطبيق:
//   Firebase Console → مشروع rhhal-6de3d → Build → Firestore Database
//   → تبويب Rules → الصق هذا الملف بالكامل → Publish.
//
// ⚠️ ملاحظة صريحة: هذا «حاجز أمان» ضد الحذف والعبث العرضي، وليس جدارًا
//    كاملًا. أي شخص يملك إعدادات المشروع (وهي داخل ملفات الموقع) يستطيع
//    كتابة بيانات صحيحة الشكل. للحماية الحقيقية يلزم تفعيل Firebase Auth
//    (مؤجّل بقرار تشغيلي).
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 الإعدادات: تحوي كل حسابات المعلمين والمجموعات ونقاط التحضير.
    //    تُقرأ وتُنشأ وتُحدَّث، لكن لا تُحذف أبدًا (أخطر عملية مسح).
    match /settings/{docId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    // بيانات المرحلة المتوسطة والبيانات العامة — مفتوحة (استخدام داخلي).
    match /students/{id}   { allow read, write: if true; }
    match /logs/{id}       { allow read, write: if true; }
    match /attendance/{id} { allow read, write: if true; }
    match /memos/{id}      { allow read, write: if true; }
    match /auditLogs/{id}  { allow read, write: if true; }
    match /migrations/{id} { allow read, write: if true; }

    // بيانات المراحل الهرمية (الثانوية والمتوسطة) وكل وثائقها الفرعية.
    match /stages/{stage}/{document=**} { allow read, write: if true; }

    // أي كولكشن غير معروف: مقفل افتراضيًا (يمنع إنشاء بيانات عشوائية خارج البنية).
    // ملاحظة: إن أضفت كولكشن جديدًا للتطبيق مستقبلًا، أضِف له سطرًا هنا.
  }
}
